# Cloudflare Pages custom response headers

# Icons — short TTL so stale icons clear quickly after deploys
/favicon.png
  Cache-Control: public, max-age=86400, stale-while-revalidate=86400

/apple-touch-icon.png
  Cache-Control: public, max-age=86400, stale-while-revalidate=86400

/icon-192.png
  Cache-Control: public, max-age=86400, stale-while-revalidate=86400

/icon-512.png
  Cache-Control: public, max-age=86400, stale-while-revalidate=86400

/manifest.json
  Cache-Control: public, max-age=86400, stale-while-revalidate=86400
