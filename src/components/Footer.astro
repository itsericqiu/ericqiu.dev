---
const socialLinks = [
  { label: "LinkedIn", href: "https://linkedin.com/in/eric-qiu", me: true },
  { label: "Instagram", href: "https://instagram.com/itsericqiu", me: true },
  { label: "GitHub", href: "https://github.com/itsericqiu", me: true },
];

const year = new Date().getFullYear();
---

<footer>
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-bio">
        <div class="bio-row">
          <div class="avatar-col">
            <img
              src="/profile.jpg"
              alt="Eric Qiu"
              class="profile-photo"
              width="77"
              height="77"
              loading="lazy"
            />
          </div>
          <div class="bio-text-col">
            <p class="bio-name">Eric Qiu</p>
            <p class="bio-description">
              From Hamilton, Ontario — University of Waterloo CS grad, now based in
              New York City. I build distributed systems at Bloomberg and spend my
              evenings with a camera or chasing a good pour over.
            </p>
          </div>
        </div>
      </div>
      <div class="footer-links">
        {socialLinks.map((link) => (
          <p>
            <a
              href={link.href}
              target="_blank"
              rel={link.me ? "me noopener noreferrer" : "noopener noreferrer"}
              class="social-link"
            >
              {link.label}
            </a>
          </p>
        ))}
<p class="email-text">hello[at]ericqiu[dot]io</p>
      </div>
    </div>
    <div class="footer-bottom">
      <p class="copyright">&copy; {year} Eric Qiu</p>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border-subtle);
  }

  .footer-inner {
    max-width: var(--footer-width);
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .footer-bio {
    flex: 1;
  }

  .bio-row {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .avatar-col {
    flex-shrink: 0;
  }

  .profile-photo {
    width: 77px;
    height: 77px;
    border-radius: 100px;
    object-fit: cover;
  }

  .bio-text-col {
    flex: 1;
  }

  .bio-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.125rem;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
    font-optical-sizing: auto;
  }

  .bio-description {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 480px;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex-shrink: 0;
  }

  .social-link {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    background-image: linear-gradient(var(--accent), var(--accent));
    background-repeat: no-repeat;
    background-position: 0% 100%;
    background-size: 0% 1px;
    transition: color 0.3s var(--transition-reveal), background-size 0.3s var(--transition-reveal);
  }

  .social-link:hover {
    color: var(--text-primary);
    background-size: 100% 1px;
  }

  .social-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .email-text {
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--text-secondary);
  }

  .footer-bottom {
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-subtle);
  }

  .copyright {
    font-size: 0.8125rem;
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .footer-top {
      flex-direction: column;
      gap: 1.5rem;
    }

    .bio-row {
      flex-direction: column;
    }
  }
</style>
