---

---

<section class="hero" id="top">
  <div class="hero-content">
    <div class="hero-image">
      <img
        src="/coffee-3d.png"
        alt="Eric Qiu — Software Engineer based in New York City"
        width="480"
        height="421"
      />
    </div>
    <div class="hero-text">
      <h1>Hi, I'm Eric <span class="wave">👋</span></h1>
      <p class="subtitle">
        a <span class="gradient-text"><strong>Software Engineer &amp; Coffee Addict</strong></span> based in New York City, currently working in Cloud Storage Infrastructure at Bloomberg.
      </p>
      <div class="cta-wrapper">
        <a
          href="https://photos.ericqiu.io"
          target="_blank"
          rel="noopener noreferrer"
          class="cta-button"
        >
          <span class="btn-emoji">📷</span>
          <span class="btn-text"><strong>I play with cameras in my spare time →</strong></span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 20px 25px 40px;
    background: #000000;
  }

  .hero-content {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 40px;
    min-height: 560px;
  }

  .hero-image {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  .hero-image img {
    width: 100%;
    max-width: 440px;
    height: auto;
    object-fit: contain;
  }

  .hero-text {
    flex: 1.5;
  }

  h1 {
    font-family: var(--font-sans);
    font-size: 4rem;
    font-weight: 900;
    color: #ffffff;
    margin-bottom: 0.75rem;
    line-height: 1.2;
    letter-spacing: -0.04em;
  }

  .subtitle {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    color: #ffffff;
    line-height: 1.4;
    margin-bottom: 2rem;
    letter-spacing: -0.01em;
  }

  .wave {
    font-family: "Apple Color Emoji", "Segoe UI Emoji", "Noto Color Emoji", sans-serif;
    font-style: normal;
    font-weight: normal;
    -webkit-font-smoothing: auto;
    font-variant-emoji: emoji;
  }

  .gradient-text {
    background: var(--gradient-water);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .cta-wrapper {
    margin-top: 1rem;
  }

  .cta-button {
    display: inline-flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem 1.5rem;
    background: #ffffff;
    color: #000000;
    border-radius: 999px;
    font-family: var(--font-heading);
    font-size: 0.95rem;
    text-align: left;
    box-shadow: 0 10px 20px -10px #6E79D6;
    transition: all var(--transition);
  }

  .btn-emoji {
    flex-shrink: 0;
    line-height: 1.4;
  }

  .btn-text {
    flex: 1;
  }

  .cta-button:hover {
    transform: translateY(-1px);
    box-shadow: 0 14px 24px -10px #6E79D6;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 40px 25px 60px;
    }

    .hero-content {
      flex-direction: column;
      align-items: flex-start;
      gap: 28px;
      min-height: auto;
    }

    .hero-image {
      flex: none;
      width: 80%;
      align-self: center;
    }

    .hero-text {
      flex: none;
      width: 100%;
    }

    h1 {
      font-size: 2.5rem;
    }

    .subtitle {
      font-size: 1.25rem;
    }

    .cta-button {
      display: flex;
      width: 100%;
      box-sizing: border-box;
      align-items: center;
      text-align: center;
      justify-content: center;
    }

    .btn-text {
      text-align: center;
    }
  }
</style>
