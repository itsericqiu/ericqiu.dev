---
const links = [
  { label: "Github", href: "https://github.com/itsericqiu" },
  { label: "LinkedIn", href: "https://linkedin.com/in/eric-qiu" },
  { label: "Instagram", href: "https://instagram.com/itsericqiu" },
];
---

<nav>
  <div class="nav-inner">
    <a href="/" class="logo" aria-label="Home">
      <!-- Full name: desktop -->
      <span class="logo-text">Eric <em>Qiu.</em></span>
      <!-- Compact mark: mobile -->
      <span class="logo-mark" aria-hidden="true">E<em>Q</em>.</span>
    </a>
    <div class="nav-right">
      <div class="nav-links">
        {links.map((link) => (
          <a href={link.href} target="_blank" rel="noopener noreferrer" class="nav-link">
            {link.label}
          </a>
        ))}
      </div>
      <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode">
        <svg class="icon-sun" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        <svg class="icon-moon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
    </div>
  </div>
</nav>

<script is:inline>
  (function() {
    var btn = document.getElementById('theme-toggle');
    if (!btn) return;

    function getEffectiveTheme() {
      var explicit = document.documentElement.getAttribute('data-theme');
      if (explicit === 'dark' || explicit === 'light') return explicit;
      return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }

    function updateIcons() {
      var isDark = getEffectiveTheme() === 'dark';
      btn.querySelector('.icon-sun').style.display = isDark ? 'block' : 'none';
      btn.querySelector('.icon-moon').style.display = isDark ? 'none' : 'block';
    }

    updateIcons();

    btn.addEventListener('click', function() {
      var next = getEffectiveTheme() === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      updateIcons();
    });

    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function() {
      updateIcons();
    });
  })();
</script>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: 60px;
    max-height: 60px;
    background: var(--bg-nav);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-subtle);
    transition: background var(--transition);
  }

  .nav-inner {
    padding: 0 2rem;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    color: var(--text-primary);
  }

  /* Desktop: full name */
  .logo-text {
    display: inline;
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    font-optical-sizing: auto;
    line-height: 1;
  }

  .logo-text em {
    font-style: italic;
  }

  /* Mobile: EQ. mark */
  .logo-mark {
    display: none;
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    font-optical-sizing: auto;
    line-height: 1;
  }

  .logo-mark em {
    font-style: italic;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-links {
    display: flex;
    gap: 1.75rem;
  }

  .nav-link {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--text-secondary);
    background-image: linear-gradient(var(--text-primary), var(--text-primary));
    background-repeat: no-repeat;
    background-position: 0% 100%;
    background-size: 0% 1px;
    transition: color 0.3s var(--transition-reveal), background-size 0.3s var(--transition-reveal);
  }

  .nav-link:hover {
    color: var(--text-primary);
    background-size: 100% 1px;
  }

  .nav-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
    border-radius: 2px;
  }

  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border: none;
    background: none;
    color: var(--text-secondary);
    cursor: pointer;
    transition: color 0.3s var(--transition-reveal), transform 0.3s var(--transition-reveal);
    line-height: 1;
  }

  .theme-toggle:hover {
    color: var(--text-primary);
    transform: rotate(20deg);
  }

  .theme-toggle:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
    border-radius: 2px;
  }

  /* JS controls icon visibility via inline style */
  .icon-sun, .icon-moon {
    display: none;
  }

  @media (max-width: 480px) {
    .nav-inner {
      padding: 0 1.25rem;
    }

    .nav-links {
      gap: 1rem;
    }

    .nav-link {
      font-size: 0.8125rem;
    }

    /* Swap: hide full name, show compact mark */
    .logo-text {
      display: none;
    }

    .logo-mark {
      display: inline;
    }
  }
</style>
