---
import { site } from "../site";
---

<section class="hero" id="top">
  <div class="hero-inner">
    <div class="hero-kicker">
      <span class="kicker-line">{site.kicker}</span>
    </div>
    <h1 class="hero-name">
      <span class="hero-line" style="animation-delay: 0.1s">{site.nameFirst}</span>
      <span class="hero-line" style="animation-delay: 0.3s; font-style: italic;">{site.nameLast}</span>
    </h1>
    <p class="hero-bio">
      {site.bio}
    </p>
    <p class="hero-bio hero-bio-aside" style="animation-delay: 0.45s">
      {site.bioAside}
    </p>
    <div class="hero-cta">
      <a href="https://photos.ericqiu.io" target="_blank" rel="noopener noreferrer"
         class="hero-link link-underline">I also shoot photos →</a>
    </div>
  </div>
</section>

<style>
  /* Animatable gradient position for the diagonal scan wipe */
  @property --scan-pos {
    syntax: '<percentage>';
    initial-value: -22%;
    inherits: false;
  }

  @keyframes scan-wipe {
    from { --scan-pos: -22%; }
    to   { --scan-pos: 122%; }
  }

  .hero {
    padding: 120px 25px 80px;
    background: var(--bg-primary);
    min-height: auto;
    display: flex;
    align-items: flex-start;
  }

  .hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    width: 100%;
  }

  .hero-kicker {
    margin-bottom: 0.875rem;
    animation: line-reveal 0.5s var(--transition-reveal) 0s both;
  }

  .kicker-line {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: 2rem;
    padding-bottom: 0.05em;
    display: flex;
    flex-direction: column;
    font-optical-sizing: auto;
    font-feature-settings: "liga" 1, "dlig" 1;
  }

  /* "Eric" — color driven by JS; "Qiu." inherits --text-primary from .hero-name */
  .hero-line:first-child {
    /* initial color set inline by script */
  }

  /* Diagonal scan wipe: gradient boundary sweeps across "Eric" at 55° */
  .hero-line:first-child.is-scanning {
    background: linear-gradient(
      55deg,
      var(--seg-new) calc(var(--scan-pos) - 12%),
      var(--seg-old) calc(var(--scan-pos) + 12%)
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    /* animation driven by JS via el.style.animation to avoid cascade triggering line-reveal replay */
  }

  .hero-line {
    display: block;
    animation: line-reveal 0.6s var(--transition-reveal) both;
  }

  .hero-bio {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--text-secondary);
    max-width: 520px;
    margin-bottom: 1rem;
    animation: line-reveal 0.6s var(--transition-reveal) 0.35s both;
  }

  .hero-bio-aside {
    font-size: 0.9375rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
  }

  .hero-cta {
    animation: line-reveal 0.5s var(--transition-reveal) 0.5s both;
  }

  .hero-link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    color: var(--accent);
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .hero {
      padding: 115px 20px 70px;
    }

    .hero-name {
      font-size: clamp(2.75rem, 16vw, 4rem);
    }

    .hero-kicker {
      margin-bottom: 1.75rem;
    }
  }
</style>

<script>
(function () {
  var COLORS = {
    light: ['#7E5F28', '#2A6B5E', '#1B2D45', '#8B3A2A'],
    dark:  ['#D4A574', '#A3BC85', '#8A9FC2', '#C4896A', '#B89FD4', '#7DBFB0']
  };

  var colorIdx = 0;
  var scanning = false;
  var scanGen  = 0;
  var curColor = '';

  var el = document.querySelector('#top .hero-line');

  function isDark()   { return document.documentElement.dataset.theme === 'dark'; }
  function palette()  { return COLORS[isDark() ? 'dark' : 'light']; }

  /* Set the initial color immediately */
  curColor = palette()[0];
  el.style.color = curColor;

  /* After the entry line-reveal finishes, freeze animation so removing .is-scanning
     later doesn't cascade back to line-reveal and replay it. */
  el.addEventListener('animationend', function onReveal(e) {
    if (e.animationName !== 'line-reveal') return;
    el.removeEventListener('animationend', onReveal);
    el.style.animation = 'none';
  });

  function doScan(oldColor, newColor) {
    if (scanning) return;
    scanning = true;
    var gen = ++scanGen;

    el.style.setProperty('--seg-old', oldColor);
    el.style.setProperty('--seg-new', newColor);
    /* Drive animation via inline style — keeps it out of the CSS cascade so
       removing .is-scanning won't revert to line-reveal. */
    el.style.animation = 'scan-wipe 1.0s ease-in-out forwards';
    el.classList.add('is-scanning');

    el.addEventListener('animationend', function onEnd(e) {
      if (e.animationName !== 'scan-wipe') return;
      el.removeEventListener('animationend', onEnd);
      if (scanGen !== gen) return; /* aborted (e.g. theme switch mid-scan) */
      el.style.color = newColor;
      el.classList.remove('is-scanning');
      el.style.animation = 'none';
      scanning = false;
    });
  }

  function advance() {
    var oldColor = curColor;
    colorIdx = (colorIdx + 1) % palette().length;
    curColor = palette()[colorIdx];
    doScan(oldColor, curColor);
  }

  setInterval(advance, 4000);

  /* When dark/light mode toggles, snap to the equivalent color in the new palette */
  new MutationObserver(function () {
    var p = palette();
    colorIdx = colorIdx % p.length;
    var c = p[colorIdx];
    curColor = c;
    if (scanning) {
      ++scanGen;        /* abort in-progress scan */
      scanning = false;
      el.classList.remove('is-scanning');
    }
    el.style.color = c;
  }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
})();
</script>
