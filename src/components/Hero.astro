---
import { site } from "../site";
---

<section class="hero" id="top">
  <div class="hero-inner">
    <div class="hero-kicker">
      <span class="kicker-line">{site.kicker}</span>
    </div>
    <h1 class="hero-name">
      <span class="hero-line" style="animation-delay: 0.1s">{site.nameFirst}</span>
      <span class="hero-line" style="animation-delay: 0.3s; font-style: italic;">{site.nameLast}</span>
    </h1>
    <p class="hero-bio">
      {site.bio}
    </p>
    <p class="hero-bio hero-bio-aside" style="animation-delay: 0.45s">
      {site.bioAside}
    </p>
    <div class="hero-cta">
      <a href="https://photos.ericqiu.io" target="_blank" rel="noopener noreferrer"
         class="hero-link link-underline">I also shoot photos →</a>
    </div>
  </div>
</section>

<style>
  /* Register --seg-color as a typed <color> so keyframes interpolate smoothly.
     inherits: true lets child elements pick up the animated value. */
  @property --seg-color {
    syntax: '<color>';
    initial-value: #7E5F28;
    inherits: true;
  }

  /* Light mode: amber → verdigris → navy → oxide → amber */
  @keyframes seg-light {
    0%, 20%  { --seg-color: #7E5F28; }
    25%, 45% { --seg-color: #2A6B5E; }
    50%, 70% { --seg-color: #1B2D45; }
    75%, 95% { --seg-color: #8B3A2A; }
    100%     { --seg-color: #7E5F28; }
  }

  /* Dark mode: lighter versions of the same hues */
  @keyframes seg-dark {
    0%, 20%  { --seg-color: #D4A574; }
    25%, 45% { --seg-color: #7EC8B4; }
    50%, 70% { --seg-color: #7A98B0; }
    75%, 95% { --seg-color: #C47860; }
    100%     { --seg-color: #D4A574; }
  }

  /* Kicker breathing pulse — subtle opacity wave, 16s to loosely track the color cycle */
  @keyframes kicker-pulse {
    0%, 100% { opacity: 0.6; }
    50%      { opacity: 1; }
  }

  .hero {
    padding: 120px 25px 80px;
    background: var(--bg-primary);
    min-height: auto;
    display: flex;
    align-items: flex-start;
  }

  .hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    width: 100%;
  }

  .hero-kicker {
    margin-bottom: 0.875rem;
    animation:
      line-reveal 0.5s var(--transition-reveal) 0s both,
      kicker-pulse 16s ease-in-out 1s infinite;
  }

  .kicker-line {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: 2rem;
    padding-bottom: 0.05em;
    display: flex;
    flex-direction: column;
    font-optical-sizing: auto;
    font-feature-settings: "liga" 1, "dlig" 1;
    animation: seg-light 16s ease-in-out infinite;
  }

  /* "Eric" cycles through accent colors; "Qiu." keeps --text-primary */
  .hero-line:first-child {
    color: var(--seg-color);
  }

  :global([data-theme="dark"]) .hero-name {
    animation-name: seg-dark;
  }

  .hero-line {
    display: block;
    animation: line-reveal 0.6s var(--transition-reveal) both;
  }

  .hero-bio {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--text-secondary);
    max-width: 520px;
    margin-bottom: 1rem;
    animation: line-reveal 0.6s var(--transition-reveal) 0.35s both;
  }

  .hero-bio-aside {
    font-size: 0.9375rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
  }

  .hero-cta {
    animation: line-reveal 0.5s var(--transition-reveal) 0.5s both;
  }

  .hero-link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    color: var(--accent);
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .hero {
      padding: 115px 20px 70px;
    }

    .hero-name {
      font-size: clamp(2.75rem, 16vw, 4rem);
    }

    .hero-kicker {
      margin-bottom: 1.75rem;
    }
  }
</style>
