---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import EducationCard from "../components/EducationCard.astro";
import Footer from "../components/Footer.astro";

const experiences = [
  {
    company: "Bloomberg LP",
    roles: [
      { title: "Senior Software Engineer", dates: "Jun 2021 – Present" },
      { title: "Software Engineering Co-op", dates: "Jan – Apr 2020" },
    ],
    description:
      "Working in Software Infrastructure to architect and develop managed multi-tenant distributed DR-1 compliant cloud services in use by over 300 teams across all businesses and powering mission-critical applications at Bloomberg Engineering and Global Data.",
    href: "https://www.bloomberg.com/company/values/tech-at-bloomberg/",
    logoSrc: "/logos/bloomberg.png",
    logoAlt: "Bloomberg LP logo",
    invertOnDark: true,
  },
  {
    company: "Addepar",
    roles: [{ title: "Software Engineering Co-op", dates: "Sep – Dec 2020" }],
    description:
      "Designed and developed full-stack implementation of 2FA auditing and management tools for firm administrators within Addepar's portfolio analysis and financial graph product for Family Offices, Private Offices, and RIAs.",
    href: "https://addepar.com",
    logoSrc: "/logos/addepar.png",
    logoAlt: "Addepar logo",
    invertOnDark: true,
  },
  {
    company: "Postmates",
    roles: [{ title: "Software Engineering Co-op", dates: "May – Aug 2019" }],
    description:
      "Architected and led multi-developer team in tandem with Product Design to introduce automated self-service support workflows for Postmates Couriers including implementations in CRM, database, server job queue management in Kubernetes-based backend, and in-app/in-browser experience.",
    href: "https://postmates.com",
    logoSrc: "/logos/postmates.png",
    logoAlt: "Postmates logo",
    invertOnDark: true,
  },
  {
    company: "Bloomberg LP",
    roles: [
      { title: "Software Engineering Co-op", dates: "Sep – Dec 2018" },
    ],
    description:
      "Trained and productionized machine learning model along with accompanying data pipeline to serve a new hybrid higher-quality and lower-latency data source for implied equity options volatility surfaces in Terminal and for Enterprise Data clients. Optimized Derivatives Data applications for performance.",
    href: "https://www.bloomberg.com/company/values/tech-at-bloomberg/",
    logoSrc: "/logos/bloomberg.png",
    logoAlt: "Bloomberg LP logo",
    invertOnDark: true,
  },
  {
    company: "BMO Capital Markets",
    roles: [
      { title: "Quantitative Developer Co-op", dates: "Jan – Apr 2018" },
    ],
    description:
      "Prototyped proof-of-concept for blockchain-based bond-issuance platform analogous to ICOs for the Fixed Income, Currencies & Commodities desk. Assisted Data Cognition desk in work on solutions for mining trade and transaction data from Bloomberg Terminal and Symphony messages.",
    href: "https://capitalmarkets.bmo.com/en/",
    logoSrc: "/logos/bmo.png",
    logoAlt: "BMO Capital Markets logo",
    invertOnDark: false,
  },
  {
    company: "LCBO",
    roles: [{ title: "Full Stack Developer Co-op", dates: "May – Aug 2017" }],
    description:
      "Worked on full-stack development of in-store 3D inventory and product mapping solution for customer and sales representatives. Visited retail locations piloting the solution to conduct user research. Prototyped solutions for technology-based KYC applications and age verification.",
    href: "https://www.lcbonext.com",
    logoSrc: "/logos/lcbo.png",
    logoAlt: "LCBO logo",
    invertOnDark: true,
  },
];

const education = [
  {
    school: "University of Waterloo",
    program: "Bachelor of Computer Science",
    department: "David R. Cheriton School of Computer Science",
    dates: "2016 – 2021",
    courses: [
      "Data-Intensive Distributed Systems",
      "Human-Computer Interaction",
      "Artificial Intelligence",
      "Software Specification & Testing",
    ],
    href: "https://uwaterloo.ca",
    logoSrc: "/logos/waterloo.png",
    logoAlt: "University of Waterloo logo",
    invertOnDark: false,
  },
  {
    school: "Pohang University of Science & Technology (POSTECH)",
    program: "International Exchange Student",
    department: "Department of Computer Science & Engineering",
    dates: "2019",
    courses: ["Compilers", "Automata Theory", "Computer Vision"],
    href: "https://postech.ac.kr/eng/",
    logoSrc: "/logos/postech.png",
    logoAlt: "POSTECH logo",
    invertOnDark: false,
  },
];

const techStack = [
  { category: "Languages", items: ["Go", "Python", "Java", "TypeScript"] },
  { category: "Infrastructure", items: ["Kubernetes", "AWS", "Distributed Systems", "DR-1 Compliance"] },
  { category: "Specialties", items: ["Full-Stack Development", "Human-Computer Interaction", "Cloud Infrastructure"] },
];
---

<Base
  title="Eric Qiu — Senior Software Engineer"
  description="Senior Software Engineer based in New York City at Bloomberg Engineering. University of Waterloo CS graduate specializing in distributed systems, full-stack development, and cloud infrastructure."
>
  <Nav />
  <main id="main-content">
    <Hero />

    <!-- Work Experience -->
    <section class="section" id="work" aria-label="Work Experience">
      <div class="section-inner">
        <h2 class="section-title">Work</h2>
        <div class="experience-list">
          {experiences.map((exp, i) => (
            <article class="experience-entry reveal-entry" style={`transition-delay: ${i * 60}ms`}>
              <div class="entry-body">
                <div class="entry-header">
                  <h3 class="entry-company">
                    <a href={exp.href} target="_blank" rel="noopener noreferrer" class="link-underline">{exp.company}</a>
                  </h3>
                  <div class="entry-roles">
                    {exp.roles.map(role => (
                      <p class="entry-role-line">
                        <span class="entry-role-title">{role.title}</span>
                        <span class="entry-dates">{role.dates}</span>
                      </p>
                    ))}
                  </div>
                </div>
                <p class="entry-description">{exp.description}</p>
              </div>
              {exp.logoSrc && (
                <div class="entry-logo">
                  <a href={exp.href} target="_blank" rel="noopener noreferrer" tabindex="-1" aria-hidden="true">
                    <img src={exp.logoSrc} alt={exp.logoAlt}
                      class:list={["entry-logo-img", { "invert-on-dark": exp.invertOnDark }]}
                      loading="lazy" />
                  </a>
                </div>
              )}
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Education -->
    <section class="section" id="education" aria-label="Education">
      <div class="section-inner">
        <h2 class="section-title">Education</h2>
        {education.map((edu) => <EducationCard {...edu} />)}
      </div>
    </section>

    <!-- Skills -->
    <section class="section" id="skills" aria-label="Skills">
      <div class="section-inner">
        <h2 class="section-title">What I Do</h2>
        <p class="skills-statement">
          Distributed systems, full-stack development, and human-computer interaction.
        </p>
        <div class="tech-stack">
          {techStack.map(group => (
            <div class="tech-group">
              <span class="tech-category">{group.category}</span>
              <span class="tech-items">{group.items.join(" · ")}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section" id="contact" aria-label="Contact">
      <div class="section-inner">
        <h2 class="section-title">Get in touch</h2>
        <p class="cta-tagline">Open to discussing infrastructure, system design, specialty coffee, or photography.</p>
        <div class="cta-links">
          <a href="https://linkedin.com/in/eric-qiu" target="_blank" rel="noopener noreferrer" class="cta-text-link link-underline">LinkedIn →</a>
          <a href="https://ericqiu.io" target="_blank" rel="noopener noreferrer" class="cta-text-link link-underline">Chat with me →</a>
        </div>
      </div>
    </section>

    <!-- Photography callout -->
    <div class="photo-callout">
      <span class="photo-callout-text">I also shoot photos.</span>
      <a
        href="https://photos.ericqiu.io"
        target="_blank"
        rel="noopener noreferrer"
        class="photo-callout-link link-underline"
      >
        See my photos →
      </a>
    </div>
  </main>
  <Footer />
</Base>

<style>
  .section {
    padding: 60px 25px;
  }

  .section-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 3rem;
  }

  /* Experience list */
  .experience-list {
    display: flex;
    flex-direction: column;
  }

  .experience-entry {
    display: flex;
    flex-direction: row;
    gap: 2rem;
    padding: 2.5rem 0;
    border-top: 1px solid var(--border-subtle);
    position: relative;
  }

  .entry-body {
    flex: 1;
    min-width: 0;
  }

  .experience-entry:last-child {
    border-bottom: 1px solid var(--border-subtle);
  }

  .experience-entry::before {
    content: '';
    position: absolute;
    left: -25px;
    top: 0;
    bottom: 0;
    width: 0;
    background: var(--accent);
    transition: width 0.35s var(--transition-reveal);
  }

  .experience-entry:hover::before {
    width: 3px;
  }

  .entry-header {
    margin-bottom: 1rem;
  }

  .entry-company {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.15;
    margin-bottom: 0.5rem;
    font-optical-sizing: auto;
    font-feature-settings: "liga" 1;
  }

  .entry-company a {
    color: inherit;
    text-decoration: none;
  }

  .entry-roles {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .entry-role-line {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .entry-role-title {
    color: var(--text-secondary);
  }

  .entry-dates {
    color: var(--accent);
    letter-spacing: 0.04em;
  }

  .entry-logo {
    flex-shrink: 0;
    width: 180px;
    display: flex;
    align-items: center;
    align-self: center;
    justify-content: flex-end;
  }

  .entry-logo-img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    opacity: 0.8;
    transition: opacity 0.25s ease;
  }

  .experience-entry:hover .entry-logo-img {
    opacity: 1;
  }

  .entry-description {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.75;
    max-width: 680px;
  }

  /* Skills */
  .skills-statement {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 300;
    color: var(--text-primary);
    line-height: 1.4;
    letter-spacing: -0.01em;
    max-width: 700px;
    margin-bottom: 2.5rem;
    font-optical-sizing: auto;
  }

  .tech-stack {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .tech-group {
    display: flex;
    gap: 1rem;
    align-items: baseline;
    flex-wrap: wrap;
  }

  .tech-category {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    flex-shrink: 0;
    min-width: 100px;
  }

  .tech-items {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text-secondary);
    letter-spacing: 0.02em;
  }

  /* CTA */
  .cta-tagline {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    margin-bottom: 2rem;
    line-height: 1.2;
    font-optical-sizing: auto;
  }

  .cta-links {
    display: flex;
    gap: 2.5rem;
    flex-wrap: wrap;
  }

  .cta-text-link {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    letter-spacing: 0.06em;
    color: var(--accent);
    text-decoration: none;
  }

  /* Photo callout */
  .photo-callout {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-subtle);
    padding: 24px 25px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .photo-callout-text {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .photo-callout-link {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    letter-spacing: 0.06em;
    color: var(--accent);
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .experience-entry {
      flex-direction: column;
      gap: 1rem;
    }

    .entry-logo {
      align-self: flex-start;
      justify-content: flex-start;
      width: auto;
    }

    .entry-logo-img {
      height: 36px;
      width: auto;
      max-width: 140px;
      max-height: none;
      opacity: 1;
    }

    .entry-company {
      font-size: 1.375rem;
    }

    .tech-group {
      flex-direction: column;
      gap: 0.75rem;
    }

    .tech-category {
      min-width: unset;
    }

    .photo-callout {
      flex-direction: column;
      padding: 32px 25px;
      gap: 0.75rem;
    }
  }
</style>
