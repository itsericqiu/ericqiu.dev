---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  school: string;
  program: string;
  department: string;
  dates: string;
  courses: string[];
  href: string;
  logoAlt: string;
  logoSrc?: ImageMetadata;
  logoSrcDark?: ImageMetadata;
  invertOnDark?: boolean;
  secondProgram?: string;
  secondDates?: string;
}

const { school, program, department, dates, courses, href, logoAlt, logoSrc, logoSrcDark, invertOnDark = false, secondProgram, secondDates } = Astro.props;
---

<div class="edu-row">
  <div class="logo-col">
    {logoSrc && (
      <a href={href} target="_blank" rel="noopener noreferrer" tabindex="-1" aria-hidden="true">
        <Image src={logoSrc} alt={logoAlt}
          class:list={["school-logo", logoSrcDark ? "logo-light-only" : "", { "invert-on-dark": invertOnDark }]}
          widths={[220, 440]} sizes="220px"
          loading="lazy" />
        {logoSrcDark && (
          <Image src={logoSrcDark} alt={logoAlt}
            class="school-logo logo-dark-only"
            widths={[220, 440]} sizes="220px"
            loading="lazy" />
        )}
      </a>
    )}
  </div>
  <div class="text-col">
    <p class="info-line">
      <strong class="school-name">
        <a href={href} target="_blank" rel="noopener noreferrer" class="link-underline">{school}</a>
      </strong>
      <br />
      <span class="department">{department}</span>
    </p>
    <p class="program-line">
      {program} <span class="dates">{dates}</span>
    </p>
    {secondProgram && (
      <p class="program-line">
        {secondProgram} <span class="dates">{secondDates}</span>
      </p>
    )}
    <ul class="courses">
      {courses.map((course) => (
        <li>{course}</li>
      ))}
    </ul>
  </div>
</div>

<style>
  .edu-row {
    display: flex;
    gap: 30px;
    padding: 28px 0;
    width: 100%;
    max-width: var(--max-width);
  }

  .logo-col {
    flex: 0 0 33%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .school-logo {
    height: 120px;
    width: auto;
    max-width: 220px;
    object-fit: contain;
  }

  .logo-dark-only { display: none; }

  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme="light"])) .logo-light-only { display: none; }
    :global(:root:not([data-theme="light"])) .logo-dark-only  { display: block; }
  }
  :global([data-theme="dark"]) .logo-light-only { display: none; }
  :global([data-theme="dark"]) .logo-dark-only  { display: block; }

  .text-col {
    flex: 1;
  }

  .info-line {
    font-size: 1rem;
    line-height: 1.4;
    margin-bottom: 0.5rem;
  }

  .school-name {
    color: var(--text-primary);
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    font-optical-sizing: auto;
  }

  .school-name a {
    color: inherit;
    text-decoration: none;
  }

  .department {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .program-line {
    font-size: 1rem;
    margin-bottom: 0.75rem;
    color: var(--text-primary);
  }

  .dates {
    color: var(--accent-2);
  }

  .courses {
    list-style: disc;
    padding-left: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .courses li {
    font-size: 0.95rem;
    color: var(--text-primary);
    line-height: 1.5;
  }

  @media (max-width: 640px) {
    .edu-row {
      flex-direction: column;
      gap: 16px;
    }

    .logo-col {
      flex: none;
      justify-content: center;
      width: 100%;
    }

    .school-logo {
      height: 80px;
      width: auto;
      max-width: 180px;
    }
  }
</style>
