---
interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage = "/og-image.png" } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Eric Qiu" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@itsericqiu" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Favicon & Manifest -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/manifest.json" />

    <!-- Theme Color -->
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#6968F7" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#000000" media="(prefers-color-scheme: dark)" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Quicksand:wght@400;500;600;700&family=Space+Mono:wght@400;700&family=Libre+Caslon+Text:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <!-- Boxicons -->
    <link rel="stylesheet" href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" />

    <!-- DNS Prefetch for external domains -->
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://unpkg.com" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Eric Qiu",
      "url": "https://ericqiu.dev",
      "jobTitle": "Senior Software Engineer",
      "worksFor": {
        "@type": "Organization",
        "name": "Bloomberg LP",
        "url": "https://www.bloomberg.com"
      },
      "alumniOf": [
        {
          "@type": "CollegeOrUniversity",
          "name": "University of Waterloo",
          "url": "https://uwaterloo.ca"
        },
        {
          "@type": "CollegeOrUniversity",
          "name": "Pohang University of Science and Technology",
          "url": "https://postech.ac.kr/eng/"
        }
      ],
      "sameAs": [
        "https://github.com/itsericqiu",
        "https://linkedin.com/in/eric-qiu",
        "https://instagram.com/itsericqiu"
      ],
      "knowsAbout": [
        "Distributed Systems",
        "Full-Stack Development",
        "Human-Computer Interaction",
        "Cloud Infrastructure"
      ],
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "New York",
        "addressRegion": "NY",
        "addressCountry": "US"
      }
    })} />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-40921B4C5L"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-40921B4C5L');
    </script>
    <!-- Theme initialization (runs before paint to prevent flash) -->
    <script is:inline>
      (function() {
        var saved = localStorage.getItem('theme');
        if (saved) {
          document.documentElement.setAttribute('data-theme', saved);
        }
        // If no saved preference, the CSS prefers-color-scheme media query handles it
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-nav">Skip to main content</a>
    <slot />
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --bg-primary: #ffffff;
    --bg-secondary: #f9fafb;
    --bg-card: #f9fafb;
    --bg-card-hover: #f0f0f0;
    --bg-nav: rgba(255, 255, 255, 0.85);
    --text-primary: #111827;
    --text-secondary: #6b7280;
    --text-muted: #9ca3af;
    --accent: #6968F7;
    --accent-dark: #5E5DF0;
    --gradient-water: linear-gradient(135deg, #2F80ED 0%, #B2FFDA 100%);
    --gradient-unicorn: linear-gradient(135deg, #FFCC33 0%, #E233FF 100%);
    --gradient-melon: linear-gradient(135deg, #D6FF7F 0%, #00B3CC 100%);
    --border-subtle: #e5e7eb;
    --card-shadow: 0px 4px 6px -2px rgba(16,24,40,0.03), 0px 12px 16px -4px rgba(16,24,40,0.08);
    --button-shadow: 0 10px 20px -10px #6E79D6;
    --font-sans: "Inter", -apple-system, BlinkMacSystemFont, sans-serif;
    --font-mono: "Space Mono", monospace;
    --font-heading: "Quicksand", sans-serif;
    --font-serif: "Libre Caslon Text", Georgia, serif;
    --max-width: 900px;
    --footer-width: 1100px;
    --transition: 0.2s ease;
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) {
      --bg-primary: #000000;
      --bg-secondary: #111111;
      --bg-card: #1a1a1a;
      --bg-card-hover: #222222;
      --bg-nav: rgba(0, 0, 0, 0.85);
      --text-primary: #ffffff;
      --text-secondary: #a0a0a0;
      --text-muted: #666666;
      --border-subtle: #222222;
      --card-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
    }
  }

  [data-theme="dark"] {
    --bg-primary: #000000;
    --bg-secondary: #111111;
    --bg-card: #1a1a1a;
    --bg-card-hover: #222222;
    --bg-nav: rgba(0, 0, 0, 0.85);
    --text-primary: #ffffff;
    --text-secondary: #a0a0a0;
    --text-muted: #666666;
    --border-subtle: #222222;
    --card-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
  }

  /* Invert only grayscale logos in dark mode */
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .invert-on-dark {
      filter: invert(1);
    }
  }

  [data-theme="dark"] .invert-on-dark {
    filter: invert(1);
  }

  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    font-family: var(--font-sans);
    background-color: var(--bg-primary);
    color: var(--text-primary);
    line-height: 1.6;
    min-height: 100vh;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  .skip-nav {
    position: absolute;
    top: -100%;
    left: 50%;
    transform: translateX(-50%);
    padding: 0.5rem 1.5rem;
    background: var(--accent);
    color: #ffffff;
    border-radius: 0 0 8px 8px;
    font-size: 0.875rem;
    z-index: 200;
    transition: top 0.2s;
  }

  .skip-nav:focus {
    top: 0;
  }

  ::selection {
    background: rgba(102, 126, 234, 0.3);
    color: var(--text-primary);
  }
</style>
