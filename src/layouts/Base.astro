---
import { light, dark } from "../palette";
import { site } from "../site";

interface Props {
  title?: string;
  description?: string;
  ogTitle?: string;
  ogImage?: string;
}

const {
  title       = site.pageTitle,
  description = site.description,
  ogTitle     = site.ogTitle,
  ogImage     = "/og-image.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Generate CSS variable blocks from palette tokens
const cssVars = `
:root {
  --bg-primary:    ${light.bgPrimary};
  --bg-secondary:  ${light.bgSecondary};
  --bg-card:       ${light.bgCard};
  --bg-nav:        ${light.bgNav};
  --text-primary:  ${light.textPrimary};
  --text-secondary:${light.textSecondary};
  --text-muted:    ${light.textMuted};
  --accent:        ${light.accent};
  --accent-light:  ${light.accentLight};
  --accent-dark:   ${light.accentDark};
  --accent-2:      ${light.accentSecondary};
  --accent-2-light:${light.accentSecondaryLight};
  --accent-2-dark: ${light.accentSecondaryDark};
  --border-subtle: ${light.borderSubtle};
  --card-shadow:   ${light.cardShadow};
  --font-sans:     "Instrument Sans", -apple-system, BlinkMacSystemFont, sans-serif;
  --font-mono:     "Space Mono", monospace;
  --font-display:  "Fraunces", Georgia, serif;
  --max-width:     900px;
  --footer-width:  1100px;
  --transition:    0.3s ease;
  --transition-reveal: cubic-bezier(0.16, 1, 0.3, 1);
}
@media (prefers-color-scheme: dark) {
  :root:not([data-theme="light"]) {
    --bg-primary:    ${dark.bgPrimary};
    --bg-secondary:  ${dark.bgSecondary};
    --bg-card:       ${dark.bgCard};
    --bg-nav:        ${dark.bgNav};
    --text-primary:  ${dark.textPrimary};
    --text-secondary:${dark.textSecondary};
    --text-muted:    ${dark.textMuted};
    --accent:        ${dark.accent};
    --accent-light:  ${dark.accentLight};
    --accent-dark:   ${dark.accentDark};
    --accent-2:      ${dark.accentSecondary};
    --accent-2-light:${dark.accentSecondaryLight};
    --accent-2-dark: ${dark.accentSecondaryDark};
    --border-subtle: ${dark.borderSubtle};
    --card-shadow:   ${dark.cardShadow};
  }
}
[data-theme="dark"] {
  --bg-primary:    ${dark.bgPrimary};
  --bg-secondary:  ${dark.bgSecondary};
  --bg-card:       ${dark.bgCard};
  --bg-nav:        ${dark.bgNav};
  --text-primary:  ${dark.textPrimary};
  --text-secondary:${dark.textSecondary};
  --text-muted:    ${dark.textMuted};
  --accent:        ${dark.accent};
  --accent-light:  ${dark.accentLight};
  --accent-dark:   ${dark.accentDark};
  --accent-2:      ${dark.accentSecondary};
  --accent-2-light:${dark.accentSecondaryLight};
  --accent-2-dark: ${dark.accentSecondaryDark};
  --border-subtle: ${dark.borderSubtle};
  --card-shadow:   ${dark.cardShadow};
}
::selection {
  background: ${light.selection};
  color: ${light.textPrimary};
}
@media (prefers-color-scheme: dark) {
  :root:not([data-theme="light"]) ::selection {
    background: ${dark.selection};
  }
}
[data-theme="dark"] ::selection {
  background: ${dark.selection};
}
`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={site.name} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={site.twitterHandle} />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Favicon & Manifest -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.png?v=2" type="image/png" sizes="256x256" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=2" />
    <link rel="manifest" href="/manifest.json" />

    <!-- Theme Color (from palette) -->
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content={light.themeColor} media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content={dark.themeColor} media="(prefers-color-scheme: dark)" />

    <!-- CSS Variables (generated from palette.ts) -->
    <Fragment set:html={`<style>${cssVars}</style>`} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Instrument+Sans:wght@400;500;600&family=Space+Mono:wght@400;700&display=optional"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Instrument+Sans:wght@400;500;600&family=Space+Mono:wght@400;700&display=optional"
        rel="stylesheet"
      />
    </noscript>

    <!-- DNS Prefetch for deferred external domains -->
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": site.name,
      "url": site.url,
      "jobTitle": "Senior Software Engineer",
      "worksFor": {
        "@type": "Organization",
        "name": "Bloomberg LP",
        "url": "https://www.bloomberg.com"
      },
      "alumniOf": [
        { "@type": "CollegeOrUniversity", "name": "University of Waterloo", "url": "https://uwaterloo.ca" },
        { "@type": "CollegeOrUniversity", "name": "Pohang University of Science and Technology", "url": "https://postech.ac.kr/eng/" }
      ],
      "sameAs": [
        "https://github.com/itsericqiu",
        "https://linkedin.com/in/eric-qiu",
        "https://instagram.com/itsericqiu"
      ],
      "description": site.description,
      "image": `${site.url}/profile.jpg`,
      "logo": `${site.url}/favicon.png`,
      "knowsAbout": ["Distributed Systems", "Full-Stack Development", "Human-Computer Interaction", "Cloud Infrastructure"],
      "address": { "@type": "PostalAddress", "addressLocality": "New York", "addressRegion": "NY", "addressCountry": "US" }
    })} />

    <!-- Google Analytics (deferred) -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-40921B4C5L');
      window.addEventListener('load', function() {
        var s = document.createElement('script');
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-40921B4C5L';
        s.async = true;
        document.head.appendChild(s);
      });
    </script>
  </head>
  <body>
    <div id="scroll-progress"></div>
    <a href="#main-content" class="skip-nav">Skip to main content</a>
    <slot />
    <script is:inline>
      (function () {
        var bar = document.getElementById('scroll-progress');
        var docHeight = 0;
        function cacheDocHeight() {
          docHeight = document.documentElement.scrollHeight - window.innerHeight;
        }
        function updateProgress() {
          // Only window.scrollY in the hot scroll path — no layout reads
          bar.style.width = (docHeight > 0 ? (window.scrollY / docHeight) * 100 : 0) + '%';
        }
        window.addEventListener('scroll', updateProgress, { passive: true });
        window.addEventListener('resize', function () { cacheDocHeight(); updateProgress(); });
        // Defer initial computation to next frame so layout is fully stable
        requestAnimationFrame(function () { cacheDocHeight(); updateProgress(); });
      })();
    </script>
    <script is:inline>
      (function () {
        function initReveal() {
          var observer = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                  entry.target.classList.add('visible');
                  observer.unobserve(entry.target);
                }
              });
            },
            { threshold: 0.05, rootMargin: '0px 0px -60px 0px' }
          );
          document.querySelectorAll('.reveal, .reveal-entry').forEach(function (el) {
            observer.observe(el);
          });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initReveal);
        } else {
          initReveal();
        }
      })();
    </script>
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  /* Invert logos to white in dark mode */
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .invert-on-dark { filter: invert(1); }
  }
  [data-theme="dark"] .invert-on-dark { filter: invert(1); }

  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    font-family: var(--font-sans);
    background-color: var(--bg-primary);
    color: var(--text-primary);
    line-height: 1.6;
    min-height: 100vh;
  }

  a { color: inherit; text-decoration: none; }

  img { max-width: 100%; height: auto; display: block; }

  #scroll-progress {
    position: fixed;
    top: 0; left: 0;
    height: 3px;
    width: 0%;
    background: var(--accent);
    z-index: 200;
    pointer-events: none;
  }

  .skip-nav {
    position: absolute;
    top: -100%;
    left: 1rem;
    padding: 0.4rem 0.75rem;
    background: var(--bg-card);
    color: var(--text-primary);
    border: 1px solid var(--border-subtle);
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    z-index: 200;
    transition: top 0.15s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }
  .skip-nav:focus { top: 0.5rem; outline: none; }

  /* Scroll reveal */
  .reveal-entry {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.6s var(--transition-reveal), transform 0.6s var(--transition-reveal);
  }
  .reveal-entry.visible { opacity: 1; transform: translateY(0); }

  .reveal {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  @keyframes line-reveal {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .link-underline {
    background-image: linear-gradient(var(--accent), var(--accent));
    background-repeat: no-repeat;
    background-position: 0% 100%;
    background-size: 0% 1px;
    transition: background-size 0.35s var(--transition-reveal);
  }
  .link-underline:hover { background-size: 100% 1px; }

  @media (prefers-reduced-motion: reduce) {
    .reveal-entry, .reveal { opacity: 1; transform: none; transition: none; }
    .hero-kicker, .hero-bio, .hero-cta, .hero-line { animation: none; opacity: 1; transform: none; }
    .link-underline { background-size: 0% 1px; transition: none; }
  }
</style>
